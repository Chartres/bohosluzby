# Copy to fastlane/.env and fill in. fastlane/.env is gitignored — never commit it.
# The App Store Connect API key (.p8) itself goes OUTSIDE the repo at:
#   ~/.appstoreconnect/private_keys/AuthKey_<ASC_KEY_ID>.p8
#
# Generate the key once: App Store Connect → Users and Access → Integrations →
# App Store Connect API → generate a key with role "App Manager". You get a
# Key ID and an Issuer ID, and a one-time .p8 download.

ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_APPLE_ID=pavol@dravecky.sk
